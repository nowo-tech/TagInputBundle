# PORT: host port mapped to the FrankenPHP container (used by make up).
PORT=8011

###> symfony/framework-bundle ###
# APP_ENV: Symfony environment (dev/test/prod). Demos use dev.
APP_ENV=dev
# APP_DEBUG: enable detailed debug output (1 in dev).
APP_DEBUG=1
# APP_SECRET: signing secret; use a local-only value in demos.
APP_SECRET=change_this_secret_key_to_a_random_value
###< symfony/framework-bundle ###

###> symfony/routing ###
# DEFAULT_URI: base URL for CLI route generation (must match PORT).
DEFAULT_URI=http://localhost:8011
###< symfony/routing ###
