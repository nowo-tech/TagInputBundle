{% extends 'base.html.twig' %}

{% block body %}
<div class="container py-4 tag-demo-shell">
    <div class="card tag-demo-card">
        <div class="card-body p-4 p-md-5">
    <h1 class="mb-2">{{ demo_title }}</h1>
    <p class="text-muted mb-4">Tagify UI on a single text field. Switch example: <a href="{{ path('app_demo_index') }}">all demos</a>.</p>

    {% if submitted_value is not null %}
        <div class="alert alert-success">
            Submitted value:
            {% if submitted_value is iterable %}
                <code>{{ submitted_value|json_encode }}</code>
            {% else %}
                <code>{{ submitted_value }}</code>
            {% endif %}
        </div>
    {% endif %}

    {{ form_start(form) }}
        {{ form_row(form.tags) }}
        <button class="btn btn-primary mt-3 px-4" type="submit">Submit tags</button>
    {{ form_end(form) }}

    {% if examples is defined and examples|length > 1 %}
        <hr class="my-4">
        <p class="small text-muted mb-2">Other examples</p>
        <div class="d-flex flex-wrap gap-2">
            {% for slug, cfg in examples %}
                <a href="{{ path('app_demo_tags', { slug: slug }) }}" class="btn btn-sm btn-outline-secondary{% if slug == demo_slug %} active{% endif %}">{{ cfg.title }}</a>
            {% endfor %}
        </div>
    {% endif %}
        </div>
    </div>
</div>

<link rel="stylesheet" href="{{ asset('bundles/nowotaginput/tag-input.css') }}">
<script src="{{ asset('bundles/nowotaginput/tag-input.js') }}"></script>
{% endblock %}
