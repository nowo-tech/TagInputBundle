<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Tag Input Demo{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background: #f5f7fb;
        }
        .tag-demo-shell {
            max-width: 760px;
        }
        .tag-demo-card {
            border: 1px solid #e9edf5;
            border-radius: 16px;
            box-shadow: 0 8px 30px rgba(17, 24, 39, 0.06);
        }
        .nowo-tag-input .tagify {
            border-radius: 0.375rem;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand" href="{{ path('app_demo_index') }}">Tag Input Bundle Demo</a>
        </div>
    </nav>
    {% block body %}{% endblock %}
</body>
</html>
