{
  "name": "@nowo-tech/tag-input-bundle",
  "version": "1.0.0",
  "description": "Assets build for Tag Input Bundle (TypeScript + Tagify)",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "glob": "^11.1.0"
    }
  },
  "scripts": {
    "build": "vite build && node .scripts/copy-tagify-css.mjs",
    "dev": "vite build --watch",
    "watch": "vite build --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@yaireo/tagify": "^4.35.6"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^2.1.9",
    "happy-dom": "^20.10.6",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^2.1.9"
  },
  "author": "Héctor Franco Aceituno <hectorfranco@nowo.tech>",
  "license": "MIT"
}
